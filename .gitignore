# Web UI: node deps + the Vite build output. webdist/ is ENTIRELY generated by `make build-web`
# and never tracked — release builds embed it via -tags prod (webui_prod.go). The tracked dev
# placeholder lives in internal/daemon/webseed/ (webui_dev.go), which Vite never touches, so the
# web build produces no git churn.
/web/node_modules/
/web/dist/
/internal/daemon/webdist/
/.playwright-mcp/
.superpowers/
